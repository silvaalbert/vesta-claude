# ── Credentials (one of the two sections below is required) ─────

# Option A — Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Option B — AWS Bedrock (used automatically when ANTHROPIC_API_KEY is absent)
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...          # only needed for temporary credentials
# AWS_DEFAULT_REGION=us-east-1   # defaults to us-east-1

# ── Vestaboard Cloud API (not required when DRY_RUN=true) ────────
# API token from cloud.vestaboard.com → Settings → API Tokens
VESTABOARD_API_TOKEN=your-cloud-api-token

# ── Optional ─────────────────────────────────────────────────────
# Print board to terminal instead of sending to device (default: true)
# Set to 'false' to send to the Vestaboard
DRY_RUN=false

# Override Vestaboard quiet hours (default: false)
VESTABOARD_FORCED=false

# Claude model to use for content generation (default: claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6
